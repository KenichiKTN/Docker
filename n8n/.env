# ======================
# Postgres
# ======================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8npass
POSTGRES_DB=n8n

# ======================
# n8n DB (Postgres)
# ======================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8npass

# ======================
# n8n security
# ======================
N8N_ENCRYPTION_KEY=f6f8ea4c6e6e4fbaba1ab687cb705c13b8173dfdacb846518894618494afc0081d94b54656744a
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=StrongPasswordHere

# ======================
# runtime
# ======================
N8N_LOG_LEVEL=info

# ======================
# n8n public URL (OAuth fix)
# ======================
N8N_HOST=n8n-ktn.duckdns.org
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n-ktn.duckdns.org/
